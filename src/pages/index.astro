---
// 外部リンク（v1 スコープ: 技術 / 暮らし / 近況 / 相談）
const LINKS = {
  zenn: '#',
  github: 'https://github.com/syotakokichi',
  note: '#',
  x: '#',
  contact: 'mailto:#',
};
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>つぶち</title>
    <meta name="description" content="自然と技術で、自由をつくる。" />
    <meta property="og:title" content="つぶち" />
    <meta property="og:description" content="自然と技術で、自由をつくる。" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://tsubuchi.com/" />
    <meta name="theme-color" content="#fdfcf9" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500&family=Noto+Serif+JP:wght@400;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <main>
      <header>
        <h1>つぶち</h1>
        <p class="copy">自然と技術で、<br />自由をつくる。</p>
      </header>

      <nav>
        <section>
          <h2>技術</h2>
          <ul>
            <li><a href={LINKS.zenn} rel="me">Zenn</a></li>
            <li><a href={LINKS.github} rel="me">GitHub</a></li>
          </ul>
        </section>

        <section>
          <h2>暮らし</h2>
          <ul>
            <li><a href={LINKS.note} rel="me">note</a></li>
          </ul>
        </section>

        <section>
          <h2>近況</h2>
          <ul>
            <li><a href={LINKS.x} rel="me">X</a></li>
          </ul>
        </section>

        <section>
          <h2>相談</h2>
          <ul>
            <li><a href={LINKS.contact}>Contact</a></li>
          </ul>
        </section>
      </nav>

      <footer>© つぶち</footer>
    </main>
  </body>
</html>

<style is:global>
  :root {
    --bg: #fdfcf9; /* 白〜生成り */
    --text: #333333; /* 墨色 */
    --text-soft: #8a8a85; /* 補助テキスト */
    --green: #7cb342; /* カエルグリーン（効かせ色） */
    --serif: 'Noto Serif JP', serif;
    --sans: 'Noto Sans JP', sans-serif;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--sans);
    font-weight: 400;
    line-height: 1.9;
    -webkit-font-smoothing: antialiased;
  }

  main {
    max-width: 560px;
    margin: 0 auto;
    padding: 24px 28px;
    /* 1画面に収める: スクロールさせない */
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  /* ---- 名前とコピー ---- */
  header h1 {
    font-family: var(--sans);
    font-size: 1.05rem;
    font-weight: 500;
    letter-spacing: 0.35em;
    display: flex;
    align-items: center;
    gap: 0.6em;
  }

  /* カエル要素: 名前の横の小さな緑の点 */
  header h1::after {
    content: '';
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--green);
    display: inline-block;
  }

  header p.copy {
    font-family: var(--serif);
    font-size: clamp(1.45rem, 5.2vw, 1.9rem);
    font-weight: 600;
    letter-spacing: 0.08em;
    line-height: 1.9;
    margin-top: 1.8rem;
  }

  /* ---- カテゴリ ---- */
  nav {
    margin-top: clamp(3rem, 9vh, 5rem);
  }

  nav section + section {
    margin-top: clamp(1.4rem, 3.5vh, 2.2rem);
  }

  nav h2 {
    font-family: var(--serif);
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.3em;
    color: var(--text);
  }

  nav ul {
    list-style: none;
    margin-top: 0.4rem;
  }

  nav li {
    display: inline-block;
    margin-right: 1.8em;
  }

  nav a {
    color: var(--text-soft);
    text-decoration: none;
    font-size: 0.92rem;
    letter-spacing: 0.12em;
    padding-bottom: 3px;
    border-bottom: 1px solid transparent;
    transition:
      color 0.25s,
      border-color 0.25s;
  }

  nav a:hover {
    color: var(--text);
    border-bottom-color: var(--green);
  }

  /* ---- フッター ---- */
  footer {
    margin-top: clamp(3rem, 9vh, 5rem);
    font-size: 0.78rem;
    letter-spacing: 0.2em;
    color: var(--text-soft);
  }
</style>
